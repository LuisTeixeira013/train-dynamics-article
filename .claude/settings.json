{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(python -m pytest *)",
      "Bash(python -m ruff *)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts/run_checks.ps1 *)",
      "PowerShell(git status *)",
      "PowerShell(git diff *)",
      "PowerShell(python -m pytest *)",
      "PowerShell(python -m ruff *)",
      "PowerShell(*scripts/run_checks.ps1*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh release create *)",
      "PowerShell(git commit *)",
      "PowerShell(git push *)",
      "PowerShell(gh pr create *)",
      "PowerShell(gh release create *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./data/private/**)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "PowerShell(Remove-Item -Recurse -Force *)",
      "PowerShell(git push --force *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"$env:CLAUDE_PROJECT_DIR\\.claude\\hooks\\quick-check.ps1\"",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
